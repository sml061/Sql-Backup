# Ignore the .env file to prevent sensitive information from being committed to version control
.env

# Ignore the virtual environment directory to avoid committing dependencies and environment-specific files
venv/

# Ignore Python bytecode files and cache directories
__pycache__/

# Ignore log files generated by the application
*.log

# Ignore backup files created by the application
*.sql
backups/

# Ignore json files
*.json